# IndustrialIQ Docker Deployment Configuration
# Copy this file to .env and update values for your environment

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=industrialiq

# Server Configuration
NODE_ENV=production

# JWT Authentication (REQUIRED - change in production!)
JWT_SECRET=change-this-to-a-secure-secret-key
JWT_EXPIRES_IN=24h

# AI/LLM Configuration (optional - leave empty for demo mode)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=gpt-4
AI_TEMPERATURE=0.7

# Business Configuration (optional - uses defaults if not set)
TAX_RATE=0.08
SHIPPING_RATE=0.02
BULK_DISCOUNT_THRESHOLD=10
BULK_DISCOUNT_RATE=0.12
