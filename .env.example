# MRO Platform - Environment Configuration
# Copy this file to .env and update with your actual values

# =======================
# Application Settings
# =======================
DEBUG=true
# SECRET_KEY must be at least 32 characters (REQUIRED in production)
SECRET_KEY=change-me-to-a-secure-key-at-least-32-chars!!
# Admin API key for dashboard access (required in production)
ADMIN_API_KEY=
PORT=8000

# =======================
# Database Configuration
# =======================
# PostgreSQL (app falls back gracefully if unavailable)
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=password
POSTGRES_DB=chatbot
DATABASE_URL=postgresql://chatbot:password@localhost:5432/chatbot

# Redis (app falls back gracefully if unavailable)
REDIS_URL=redis://localhost:6379/0

# =======================
# AI Enhancement (Optional)
# =======================
# Anthropic Claude API for enhanced responses
ANTHROPIC_API_KEY=
AI_MODEL=claude-3-5-sonnet-20241022
AI_MAX_RETRIES=3
AI_RETRY_DELAY=1.0

# Circuit breaker (protects against AI outages)
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# =======================
# Neo4j Knowledge Graph
# =======================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# =======================
# Voyage AI (Embeddings)
# =======================
VOYAGE_API_KEY=

# =======================
# Firecrawl (Web Scraping)
# =======================
# Optional — enables high-quality scraping with JS rendering and anti-bot
# Falls back to BeautifulSoup when not set
FIRECRAWL_API_KEY=

# =======================
# WhatsApp Business API (Optional)
# =======================
# Get these from Meta Business Platform
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# =======================
# Support Contact Info
# =======================
SUPPORT_EMAIL=support@company.com
SUPPORT_PHONE=1-800-TECH-HELP

# =======================
# Email / SMTP (Optional)
# =======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# =======================
# Email Ingestion Pipeline
# =======================
# Fernet encryption key for email body at rest (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
EMAIL_ENCRYPTION_KEY=
# Gmail OAuth2 — obtain credentials from Google Cloud Console (Gmail API)
# Tokens are stored per-inbox in the DB via admin API, not here.
EMAIL_POLL_INTERVAL_SECONDS=60
EMAIL_MAX_MESSAGES_PER_POLL=50
EMAIL_ATTACHMENT_DIR=data/email_attachments
EMAIL_RETENTION_DAYS=90

# =======================
# CORS (Production)
# =======================
# Comma-separated list of allowed origins (leave empty for default dev origins)
CORS_ALLOWED_ORIGINS=

# =======================
# Rate Limiting
# =======================
RATE_LIMIT_PER_MINUTE=60
