# B2B AI Chatbot MVP - Environment Variables
# Copy this file to .env and update with your actual values

# =======================
# Basic Application Settings
# =======================

DEBUG=true
SECRET_KEY=your-secret-key-here-minimum-32-characters-long-change-this
ADMIN_API_KEY=your-admin-api-key-for-dashboard-access
PORT=8000

# =======================
# Database Configuration
# =======================

# PostgreSQL (optional - app will use in-memory fallback if unavailable)
DATABASE_URL=postgresql://chatbot:password@localhost:5432/chatbot

# Redis (optional - app will use in-memory fallback if unavailable)
REDIS_URL=redis://localhost:6379/0

# =======================
# WhatsApp Business API (Optional)
# =======================

# Get these from Meta Business Platform
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_APP_SECRET=your_app_secret_for_signature_verification

# =======================
# AI Enhancement (Optional)
# =======================

# Anthropic API for enhanced responses
ANTHROPIC_API_KEY=your_anthropic_api_key

# AI Model Configuration
AI_MODEL=claude-3-5-sonnet-20241022
AI_MAX_RETRIES=3
AI_RETRY_DELAY=1.0

# =======================
# Support Contact Information
# =======================

# Configurable support contact details (shown in responses)
SUPPORT_EMAIL=support@company.com
SUPPORT_PHONE=1-800-TECH-HELP

# =======================
# Circuit Breaker Settings
# =======================

# Number of failures before circuit opens
CIRCUIT_BREAKER_THRESHOLD=5

# Seconds to wait before attempting recovery
CIRCUIT_BREAKER_TIMEOUT=60

# =======================
# Email Configuration (Optional)
# =======================

# For email notifications and alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# =======================
# Rate Limiting
# =======================

# API rate limit per minute per IP
RATE_LIMIT_PER_MINUTE=60
